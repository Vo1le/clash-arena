# ──────────────────────────────────────────────
# CLASH ARENA — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env dans Git !
# ──────────────────────────────────────────────

# Discord — https://discord.com/developers/applications
VITE_DISCORD_CLIENT_ID=TON_CLIENT_ID
DISCORD_CLIENT_SECRET=TON_CLIENT_SECRET
DISCORD_BOT_TOKEN=TON_BOT_TOKEN

# UnbelievaBoat API — https://unbelievaboat.com/api/docs
# Clé API à générer depuis le dashboard UNB (bouton "Generate Token")
UNB_API_TOKEN=TON_TOKEN_UNB

# ID du serveur Discord sur lequel UnbelievaBoat est installé
# (clic droit sur le serveur > "Copier l'ID du serveur" avec Developer Mode)
GUILD_ID=ID_DE_TON_SERVEUR

# Automatiquement injecté par Render en production
# PORT=10000
